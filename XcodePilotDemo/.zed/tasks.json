[
  {
    "label": "iOS-Runner: Build",
    "command": "/bin/zsh",
    "args": [
      "-lc",
      "export PATH=\"$HOME/.cargo/bin:$PATH\" && cd \"$ZED_WORKTREE_ROOT\" && ios-runner build"
    ],
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all",
    "use_new_terminal": false
  },
  {
    "label": "iOS-Runner: Run",
    "command": "/bin/zsh",
    "args": [
      "-lc",
      "export PATH=\"$HOME/.cargo/bin:$PATH\" && cd \"$ZED_WORKTREE_ROOT\" && ios-runner run"
    ],
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all",
    "use_new_terminal": false
  },
  {
    "label": "iOS-Runner: Resolve Swift Packages",
    "command": "/bin/zsh",
    "args": [
      "-lc",
      "export PATH=\"$HOME/.cargo/bin:$PATH\" && cd \"$ZED_WORKTREE_ROOT\" && ios-runner resolve-packages"
    ],
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all",
    "use_new_terminal": false
  }
]
